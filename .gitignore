# ── OS files (root level + anywhere sub-gitignores don't reach) ──
.DS_Store
Thumbs.db

# ── IDE folders (server has no .gitignore entry for these; root covers it) ──
.vscode/
.idea/

# ── Root-level node_modules (safety net if npm is run at repo root) ──
node_modules/

# ── client/.env is not caught by client/.gitignore (which only has *.local) ──
client/.env

# ── Claude Code project files (not for version control) ──
CLAUDE.md
.mcp.json
